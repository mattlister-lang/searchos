# Vercel project env vars (Settings → Environment Variables).
# NEXT_PUBLIC_* are safe for the browser; the service role key is SERVER-ONLY
# and must never be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated sign-in allowlist (ADR-021)
ALLOWED_EMAILS=matt.lister@offtakesearch.com
